    "music_share_api": [
      {
        "path": "/api/share/start",
        "method": "POST",
        "auth": "required",
        "consumes": "application/json",
        "request": {
          "body": {
            "sessionId": "string (required)"
          }
        },
        "responses": {
          "200": {
            "success": true,
            "sessionId": "string",
            "timestamp": "number (epoch ms)"
          },
          "400": { "success": false, "error": "string" },
          "401": { "success": false, "error": "Unauthorized", "code": "UNAUTHORIZED" },
          "409": { "success": false, "error": "string (session id already in use)" },
          "500": { "success": false, "error": "Internal server error" }
        }
      },
      {
        "path": "/api/share/{session_id}/metadata",
        "method": "POST",
        "auth": "required",
        "consumes": "application/json",
        "request": {
          "path_params": {
            "session_id": "string"
          },
          "body": "arbitrary JSON metadata object"
        },
        "responses": {
          "200": { "success": true, "listenersNotified": "number" },
          "401": { "success": false, "error": "Unauthorized" },
          "404": { "success": false, "error": "string" },
          "500": { "success": false, "error": "Internal server error" }
        }
      },
      {
        "path": "/api/share/{session_id}/audio",
        "method": "POST",
        "auth": "required",
        "consumes": "application/json",
        "request": {
          "path_params": {
            "session_id": "string"
          },
          "body": {
            "sequenceNumber": "number (recommended)",
            "data": "string (audio payload; format defined by clients)",
            "...": "additional fields may be accepted"
          }
        },
        "responses": {
          "200": { "success": true, "buffered": true },
          "401": { "success": false, "error": "Unauthorized" },
          "404": { "success": false, "error": "string" },
          "500": { "success": false, "error": "Internal server error" }
        }
      },
      {
        "path": "/api/share/{session_id}/stop",
        "method": "POST",
        "auth": "required",
        "request": {
          "path_params": {
            "session_id": "string"
          }
        },
        "responses": {
          "200": {
            "success": true,
            "stats": "object (implementation-defined keys from stop_session)"
          },
          "401": { "success": false, "error": "Unauthorized" },
          "404": { "success": false, "error": "Session not found" },
          "500": { "success": false, "error": "Internal server error" }
        }
      },
      {
        "path": "/api/share/{session_id}/status",
        "method": "GET",
        "auth": "required",
        "request": {
          "path_params": {
            "session_id": "string"
          }
        },
        "responses": {
          "200": "session status object from music_share.get_session_status",
          "401": { "isActive": false, "error": "Unauthorized" },
          "404": { "isActive": false, "error": "Session not found" },
          "500": { "error": "Internal server error" }
        }
      },
      {
        "path": "/api/share/{session_id}/metadata",
        "method": "GET",
        "auth": "required",
        "request": {
          "path_params": {
            "session_id": "string"
          }
        },
        "responses": {
          "200": "metadata object",
          "401": { "error": "Unauthorized" },
          "404": { "error": "Session not found or no metadata available" },
          "500": { "error": "Internal server error" }
        }
      },
      {
        "path": "/api/share/{session_id}/audio",
        "method": "GET",
        "auth": "required",
        "request": {
          "path_params": {
            "session_id": "string"
          },
          "query_params": {
            "since": "integer (optional, default -1)"
          }
        },
        "responses": {
          "200": "JSON array of audio chunk objects",
          "204": "No Content",
          "401": { "error": "Unauthorized" },
          "404": { "error": "Session not found" },
          "500": { "error": "Internal server error" }
        }
      }
    ],
