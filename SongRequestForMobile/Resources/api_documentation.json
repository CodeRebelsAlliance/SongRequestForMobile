  "notes": {
    "account_engine": "engines/account_engine.py defines many routes, but no AccountEngine blueprint is registered in app/app.py, so those routes are currently inactive in this server process.",
    "fetch_set_sendin_allowed_behavior": "Current implementation returns success messages but does not call set_sendin_allowed in method='set-sendin-allowed'.",
    "response_types": "Some endpoints return Flask redirect responses (301/302/303) or HTML templates rather than JSON."
  }
