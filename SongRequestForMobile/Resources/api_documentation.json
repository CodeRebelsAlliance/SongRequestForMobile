          },
          "401": {
            "status": "unauthorized",
            "message": "unauthorized"
          }
        }
      }
    ],
    "admin_fetch_multiplex_api": [
      {
        "path": "/fetch",
        "method": "POST",
        "auth": "required",
        "description": "Single endpoint dispatching many admin operations using query parameter 'method'.",
        "request": {
          "query_params": {
            "method": "string (required)"
          },
          "body_format": "mostly form-data; some methods expect JSON",
          "common_error": {
            "401": {
              "status": "unauthorized",
              "message": "unauthorized"
            },
            "400": {
              "status": "bad request",
              "message": "wrong method"
            }
          }
        },
        "operations": {
          "add-admin-jwt-subject": {
            "form_fields": { "subject": "string" },
            "response_200": { "status": "success", "message": "added admin jwt subject" }
          },
          "remove-admin-jwt-subject": {
            "form_fields": { "subject": "string" },
            "response_200": { "status": "success", "message": "removed admin jwt subject" }
          },
          "add-api-key": {
            "form_fields": { "api_key": "string (required, length 39)" },
            "responses": {
              "200": { "status": "success", "message": "added api key" },
              "400": [
                { "status": "bad request", "message": "no api key provided" },
                { "status": "bad request", "message": "api key must be 39 characters long" }
              ]
            }
          },
          "remove-api-key": {
            "form_fields": { "api_key": "string (required)" },
            "responses": {
              "200": { "status": "success", "message": "removed api key" },
              "400": { "status": "bad request", "message": "no api key provided" }
            }
          },
          "get-admin-jwt-subjects": {
            "response_200": ["string"]
          },
          "get-database": {
            "response_200": [
              [
                "ytid:string",
                "message:string",
                "is_approved:boolean",
                "time:string"
              ]
            ]
          },
          "get-blacklist": {
            "response_200": ["ytid:string"]
          },
          "add": {
            "form_fields": { "ytid": "string" },
            "response_200": { "status": "success", "message": "added id to approved_list" }
          },
          "delete": {
            "form_fields": { "ytid": "string" },
            "response_200": { "status": "success", "message": "removed id from input_list and approved_list" }
          },
          "blacklist": {
            "form_fields": { "ytid": "string" },
            "response_200": { "status": "success", "message": "added id to black_list and removed id from other lists" }
          },
          "unblacklist": {
            "form_fields": { "ytid": "string" },
            "response_200": { "status": "success", "message": "removed id from black_list" }
          },
          "approve": {
            "form_fields": { "ytid": "string" },
            "response_200": { "status": "success", "message": "added id to approved_list and removed id from input_list" }
          },
          "unapprove": {
            "form_fields": { "ytid": "string" },
            "response_200": { "status": "success", "message": "removed id from approved_list and added id to input_list" }
          },
          "addlist": {
            "form_fields": {
              "ytids": "JSON string encoded object: {\"ytids\": [\"id1\", \"id2\"]}"
            },
            "response_200": { "status": "success", "message": "added list to approved_list" }
          },
          "clear": {
            "form_fields": { "list": "input_list | approved_list | black_list | both | all" },
            "responses": {
              "200": [
                { "status": "success", "message": "cleared input_list" },
                { "status": "success", "message": "cleared approved_list" },
                { "status": "success", "message": "cleared black_list" },
                { "status": "success", "message": "cleared approved_list and input_list" },
                { "status": "success", "message": "cleared approved_list, input_list and black_list" }
              ],
              "400": { "status": "bad request", "message": "wrong list" }
            }
          },
          "export": {
            "form_fields": { "list": "approved_list | input_list | black_list" },
            "responses": {
              "200": "application/json file download",
              "400": { "status": "bad request", "message": "wrong list" }
            }
          },
          "import": {
            "response_200": {
              "status": "success",
              "message": "das hier ist einfach noch nicht implementiert aber wir lassen den button jetzt einfach mal garnichts machen"
            }
          },
          "get-bad-words": {
            "response_200": ["string"]
          },
          "add-bad-word": {
            "form_fields": { "word": "string" },
            "response_200": { "status": "success", "message": "added bad word" }
          },
          "delete-bad-word": {
            "form_fields": { "word": "string" },
            "response_200": { "status": "success", "message": "deleted bad word" }
          },
          "get-sendin-allowed": {
            "response_200": ["boolean"]
          },
          "set-sendin-allowed": {
            "form_fields": { "sendin-allowed": "string: 'true' or other" },
            "responses": {
              "200": [
                { "status": "success", "message": "set sendin allowed true" },
                { "status": "success", "message": "set sendin allowed false" }
              ]
            }
          },
          "toggle": {
            "response_200": [
              { "status": "success", "message": "toggled sendin allowed true" },
              { "status": "success", "message": "toggled sendin allowed false" }
            ]
          },
          "set-now-playing": {
            "form_fields": {
              "now-playing-title": "string",
              "now-playing-artist": "string"
            },
            "response_200": { "status": "success", "message": "set now playing" }
          },
          "reset-now-playing": {
            "response_200": { "status": "success", "message": "reset now playing" }
          }
        }
      }
