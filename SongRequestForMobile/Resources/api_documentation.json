{
  "service": "Song Requests Server",
  "version": "generated-from-source",
  "source_files": [
    "app/app.py",
    "engines/health_check_engine.py",
    "engines/logs_engine.py",
    "engines/jwt_engine.py"
  ],
  "base_url": "/",
  "auth": {
    "admin_authenticate_decorator": {
      "supported_methods": [
        "Flask session cookie: session[Authorization] == bearer token",
        "Authorization header: Bearer <BEARER_TOKEN>",
        "JWT token (validated against external issuer/public key)"
      ],
      "note": "Routes marked as requiring auth use the @authenticate() decorator."
    }
  },
  "endpoint_groups": {
    "public_pages": [
      {
        "path": "/",
        "method": "GET",
        "returns": "text/html",
        "responses": {
          "200": "index page or sendin closed page"
        }
      },
      {
        "path": "/success",
        "method": "GET",
        "returns": "text/html",
        "responses": {
          "200": "success page"
        }
      },
      {
        "path": "/ytmusic",
        "method": "GET",
        "returns": "text/html",
        "responses": {
          "200": "YouTube Music search page"
        }
      },
      {
        "path": "/music-share",
        "method": "GET",
        "returns": "text/html",
        "responses": {
          "200": "Music Share receiver page"
        }
      },
      {
        "path": "/alreadysent",
        "method": "GET",
        "returns": "text/html",
        "responses": {
          "200": "already sent page"
        }
      },
      {
        "path": "/failure_blacklist",
        "method": "GET",
        "returns": "text/html",
        "responses": {
          "200": "blacklist failure page"
        }
      },
      {
        "path": "/failure_wrongurl",
        "method": "GET",
        "returns": "text/html",
        "responses": {
          "200": "invalid URL failure page"
        }
      },
      {
        "path": "/failure_srclosed",
        "method": "GET",
        "returns": "text/html",
        "responses": {
          "200": "send-in closed page"
        }
      },
      {
        "path": "/sendin",
        "method": "POST",
        "consumes": "application/x-www-form-urlencoded or multipart/form-data",
        "request": {
          "form_fields": {
            "ytlink": "string (YouTube URL or 11-char ID)",
            "message": "string (optional)"
          }
        },
        "responses": {
          "301": "redirects to ./success, ./failure_wrongurl, ./alreadysent, ./failure_blacklist, or ./",
          "400": {
            "content_type": "application/json",
            "body": {
              "status": "bad request",
              "message": "how tf did you manage to do this?"
            }
          }
        }
      }
    ],
    "authentication_pages": [
      {
        "path": "/login",
        "method": "POST",
        "auth": "optional (accepts form token or existing auth)",
        "request": {
          "form_fields": {
            "Authorization": "string (bearer token value)"
          }
        },
        "responses": {
          "301": "redirect ./admin (both success and failure)"
        }
      },
      {
        "path": "/logout",
        "method": "GET",
        "responses": {
          "301": "redirect ./admin"
        }
      },
      {
        "path": "/jwt-callback",
        "method": "GET",
        "request": {
          "query_params": {
            "token": "string"
          }
        },
        "responses": {
          "301": "redirect sr://authenticate?jwt=<token>; sets cookie sr_auth_token"
        }
      },
      {
        "path": "/jwt-issuer",
        "method": "GET",
        "returns": "application/json",
        "responses": {
          "200": {
            "issuer": "string"
          }
        }
      }
    ],
    "admin_pages": [
      {
        "path": "/admin",
        "method": "GET",
