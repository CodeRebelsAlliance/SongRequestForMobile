<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SongRequestForMobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SongRequestForMobile"
    xmlns:pages="clr-namespace:SongRequestForMobile.Pages"
    Title="SongRequestForMobile"
    Shell.NavBarIsVisible="False">

    <TabBar>
        <ShellContent
            Title="Add"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="AddPage">
            <Shell.Icon>
                <FontImageSource 
                    FontFamily="MaterialIcons"
                    Glyph="&#xe145;"
                    Color="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
            </Shell.Icon>
        </ShellContent>

        <ShellContent
            Title="Requests"
            ContentTemplate="{DataTemplate pages:RequestsPage}"
            Route="RequestsPage">
            <Shell.Icon>
                <FontImageSource 
                    FontFamily="MaterialIcons"
                    Glyph="&#xe896;"
                    Color="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
            </Shell.Icon>
        </ShellContent>

        <ShellContent
            Title="Player"
            ContentTemplate="{DataTemplate pages:PlayerPage}"
            Route="PlayerPage">
            <Shell.Icon>
                <FontImageSource 
                    FontFamily="MaterialIcons"
                    Glyph="&#xe037;"
                    Color="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
            </Shell.Icon>
        </ShellContent>

        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate pages:SettingsPage}"
            Route="SettingsPage">
            <Shell.Icon>
                <FontImageSource 
                    FontFamily="MaterialIcons"
                    Glyph="&#xe8b8;"
                    Color="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
            </Shell.Icon>
        </ShellContent>
    </TabBar>

</Shell>
